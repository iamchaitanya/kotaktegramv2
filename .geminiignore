.ruff_cache/
.mypy_cache/
venv/
env/
.venv/
.env

# General
logs/
tmp/
temp/
.cache/
*.log
*.cache
.DS_Store
Thumbs.db
.git/
.github/
.vscode/
.idea/

# If extras: android/, ios/, Pods/, target/